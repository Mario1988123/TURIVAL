# ======================================================================
# TURIVAL — variables de entorno
# Copia este fichero a .env.local y rellena los valores.
# ======================================================================

# Supabase (ya existe en tu proyecto Vercel)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública de la app (para enlaces /p/[token] en emails)
NEXT_PUBLIC_APP_URL=https://v0-crm-erp-saa-s-git-desarrollo-claude-vercomi.vercel.app

# =====================================
# SMTP — envío de presupuestos por email
# =====================================
# IONOS (ejemplo):
#   SMTP_HOST=smtp.ionos.es
#   SMTP_PORT=587              (STARTTLS) o 465 (SSL)
#   SMTP_SECURE=false          (true si usas puerto 465)
#   SMTP_USER=presupuestos@turival.es
#   SMTP_PASS=tu_contraseña    (o app password si 2FA activo)
#   SMTP_FROM=Turiaval <presupuestos@turival.es>
#
# Si estas variables NO se configuran, el envío queda en MODO STUB:
# no envía nada y la UI muestra un aviso amable. No bloquea el flujo.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
