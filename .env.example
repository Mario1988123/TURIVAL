# ======================================================================
# TURIVAL — variables de entorno
# Copia este fichero a .env.local y rellena los valores.
# ======================================================================

# Supabase (ya existe en tu proyecto Vercel)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública de la app (para enlaces /p/[token] en emails)
NEXT_PUBLIC_APP_URL=https://v0-crm-erp-saa-s-git-desarrollo-claude-vercomi.vercel.app

# =====================================
# SMTP — envío de presupuestos por email
# =====================================
# IONOS (ejemplo):
#   SMTP_HOST=smtp.ionos.es
#   SMTP_PORT=587              (STARTTLS) o 465 (SSL)
#   SMTP_SECURE=false          (true si usas puerto 465)
#   SMTP_USER=presupuestos@turival.es
#   SMTP_PASS=tu_contraseña    (o app password si 2FA activo)
#   SMTP_FROM=Turiaval <presupuestos@turival.es>
#
# Si estas variables NO se configuran, el envío queda en MODO STUB:
# no envía nada y la UI muestra un aviso amable. No bloquea el flujo.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# =====================================
# Backup automatico (Mario punto extra)
# =====================================
# /api/backup esta protegido. Auth opciones:
# 1) Token compartido: setea BACKUP_SECRET aqui y manda en header
#    x-backup-token al hacer la peticion (util para Vercel Cron).
# 2) Sesion admin: cualquier usuario con rol=admin en usuario_perfiles
#    puede descargar manualmente desde /configuracion.
BACKUP_SECRET=

# =====================================
# Web Push (recordatorios fichaje)
# =====================================
# Genera las claves con:  npx web-push generate-vapid-keys
# Pon la PRIVADA en Vercel server-side y la PUBLICA tanto server-side
# como con prefijo NEXT_PUBLIC_ para que el cliente pueda subscribirse.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@turival.es

# Cron de recordatorios: llama cada 5 min con header
#   x-backup-token: $BACKUP_SECRET
# desde cron-job.org / GitHub Actions / Vercel Pro Cron.
# URL: /api/fichajes/recordatorios
